# Copy this to .env and fill in your own values (never commit .env)

# Jetson node (llama-server + Neo4j)
JETSON_IP=YOUR_JETSON_IP
LLAMA_URL=http://YOUR_JETSON_IP:8080/v1/chat/completions
LLAMA_MODELS_URL=http://YOUR_JETSON_IP:8080/v1/models
VISION_LLM_URL=http://YOUR_JETSON_IP:8080/v1/chat/completions
RTSP_URL=rtsp://YOUR_JETSON_IP:8554/stream
NEO4J_URI=bolt://YOUR_JETSON_IP:7687
NEO4J_HTTP_URL=http://YOUR_JETSON_IP:7474

# Local laptop (Ollama)
REASONING_LLM_URL=http://localhost:11434/v1/chat/completions
DIVERSITY_LLM_URL=http://localhost:11434/v1/chat/completions

# Models
MODEL=your-vision-model
REASONING_LLM_MODEL=qwen3:8b
DIVERSITY_LLM_MODEL=llama3.1:8b

# Neo4j credentials
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password_here

# Optional cloud providers
OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk_...

# Optional tool integrations
TAVILY_API_KEY=tvly-...
WOLFRAM_APP_ID=your_wolfram_app_id

# Simulation
MAX_ROUNDS=2
LLM_TIMEOUT=600
